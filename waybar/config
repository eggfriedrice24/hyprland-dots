{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "temperature", "memory", "custom/separator#left", "network", "pulseaudio", "battery", "custom/separator#right", "tray"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": true,
        "all-outputs": false
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) - Mozilla Firefox": "㬚飴 $1",
            "(.*) - nvim": " $1",
            "kitty": "㬚✓ kitty",
            "Spotify": "㬚島 Spotify",
            "thunar(.*)": "㬚焔 Files$1"
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a, %b %d}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#f0b100'><b>{}</b></span>"
            }
        }
    },

    "cpu": {
        "interval": 2,
        "format": "㬚惚 {usage}%",
        "tooltip": true,
        "on-click": "kitty -e htop"
    },

    "memory": {
        "interval": 2,
        "format": "㬚嶤 {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
        "on-click": "kitty -e htop"
    },

    "temperature": {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 80,
        "format": "㬚拍 {temperatureC}ﾂｰC",
        "format-critical": "㬚拍 {temperatureC}ﾂｰC",
        "tooltip-format": "CPU Temp: {temperatureC}ﾂｰC"
    },

    "network": {
        "format-wifi": "㬚湊 {essid}",
        "format-ethernet": "㬚𡑮 Wired",
        "format-disconnected": "㬚蓑 Disconnected",
        "tooltip-format-wifi": "{signalStrength}% | {ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "㬚據 Muted",
        "format-icons": {
            "default": ["㬚柄", "㬚摩", "㬚弊"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "㬚ｄ {capacity}%",
        "format-plugged": "㬚ｄ {capacity}%",
        "format-icons": ["㬚ｎ", "㬚⊆", "㬚∪", "㬚ａ", "㬚∋"]
    },

    "custom/separator#left": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "custom/separator#right": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
