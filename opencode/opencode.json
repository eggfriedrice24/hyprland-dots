{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "google_workspace": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "set -a; [ -f \"${XDG_CONFIG_HOME:-$HOME/.config}/opencode/google-workspace.env\" ] && . \"${XDG_CONFIG_HOME:-$HOME/.config}/opencode/google-workspace.env\"; exec uvx workspace-mcp --tools gmail"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*credentials*": "deny",
      "*secret*": "deny",
      ".ssh/*": "deny",
      ".gnupg/*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rm *": "deny",
      "git push *": "deny"
    },
    "skill": {
      "*": "ask",
      "commit": "allow",
      "fix-dashes": "allow"
    },
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow"
  }
}
